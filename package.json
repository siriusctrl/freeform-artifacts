{
  "name": "freeform-artifacts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check:frontend": "tsc --noEmit && vite build",
    "check": "npm run check:frontend && npm run test:frontend-unit && npm run test:skill && npm run relay:check && npm run relay:test",
    "test:frontend-unit": "vitest run tests/relay-connection.test.ts --environment node",
    "test:skill": "node --test tests/deliver-core.test.mjs",
    "relay:types": "wrangler types --config relay/wrangler.jsonc relay/worker-configuration.d.ts",
    "relay:types:check": "wrangler types --config relay/wrangler.jsonc relay/worker-configuration.d.ts --check",
    "relay:check": "npm run relay:types:check && tsc --project relay/tsconfig.json --noEmit && wrangler deploy --config relay/wrangler.jsonc --dry-run --install-skills=false",
    "relay:test": "vitest run --config relay/vitest.config.ts",
    "relay:dev:test": "wrangler dev --config relay/wrangler.jsonc --local --ip 127.0.0.1 --port 8787 --var ENVIRONMENT:development --var RELAY_ROUTING_SECRET:development-only-relay-routing-secret-0001 --var ALLOWED_ORIGINS:http://127.0.0.1:4177",
    "relay:deploy": "wrangler deploy --config relay/wrangler.jsonc --install-skills=false",
    "verify:preview": "node scripts/verify-preview.mjs",
    "verify:relay:production": "node scripts/verify-relay-production.mjs",
    "setup:browsers": "playwright install chromium",
    "verify:ui": "playwright test",
    "verify:proof": "node scripts/record-proof.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/instrument-sans": "^5.2.8",
    "echarts": "^6.1.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
